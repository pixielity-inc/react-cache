# ─── Cache Configuration ───
VITE_CACHE_DRIVER="memory"
VITE_CACHE_PREFIX="app_"

# ─── Memory Store ───
VITE_CACHE_MEMORY_MAX_SIZE="100"
VITE_CACHE_MEMORY_TTL="300"

# ─── Redis Store ───
VITE_CACHE_REDIS_PREFIX="cache_"
VITE_CACHE_REDIS_TTL="3600"

# ─── Upstash Redis Credentials ───
# Set these to enable the Redis cache driver.
# Get your credentials from https://console.upstash.com
VITE_UPSTASH_REDIS_REST_URL=""
VITE_UPSTASH_REDIS_REST_TOKEN=""
